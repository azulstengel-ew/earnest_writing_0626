3. Update src/lib/db/sessions.ts — this file likely uses the old postgres driver too. Click on it and share what's in it so I can give you the replacement.

import { db } from "./index";
import { sessions } from "./schema";
import { eq, lt } from "drizzle-orm";
import { randomBytes } from "node:crypto";
const SESSION_DURATION_MS = 30 * 24 * 60 * 60 * 1000;
export function generateSessionId(): string {
  return randomBytes(32).toString("hex");
}
export async function createSession(userId: number): Promise<string> {
  const id = generateSessionId();
  const expiresAt = new Date(Date.now() + SESSION_DURATION_MS);
  await db.insert(sessions).values({ id, userId, expiresAt });
  return id;
}
export async function getSession(sessionId: string): Promise<{ userId: number } | null> {
  const [row] = await db
    .select()
    .from(sessions)
    .where(eq(sessions.id, sessionId))
    .limit(1);
  if (!row) return null;
  if (row.expiresAt < new Date()) {
    await db.delete(sessions).where(eq(sessions.id, sessionId));
    return null;
  }
  return { userId: row.userId };
}
export async function deleteSession(sessionId: string): Promise<void> {
  await db.delete(sessions).where(eq(sessions.id, sessionId));
}
export async function deleteExpiredSessions(): Promise<void> {
  await db.delete(sessions).where(lt(sessions.expiresAt, new Date()));
}

